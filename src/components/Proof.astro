---
import { Image } from 'astro:assets';
import serp from '../assets/proof-serp-dogsanook.png';
---
<section id="proof" style="border-bottom:1px solid var(--color-divider);">
  <div class="container" style="padding-block:clamp(56px,8vw,104px);">
    <div style="max-width:52ch;margin-bottom:clamp(32px,5vw,48px);">
      <p
        style="font-family:var(--font-body);font-size:11.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-accent-700);margin:0 0 14px;"
      >
        หลักฐานจริง / ไม่ใช่คำเคลม
      </p>
      <h2 style="font-size:clamp(28px,4vw,44px);line-height:1.18;margin:0 0 16px;">
        ไม่ต้องเชื่อเรา — ดูผลลัพธ์เอง
      </h2>
      <p
        style="font-size:17px;line-height:1.7;color:color-mix(in srgb,var(--color-text) 78%,transparent);margin:0;"
      >
        นี่คือผลการค้นหาจริงของเคสที่เราวางระบบให้ เมื่อลูกค้าค้นหาบริการในพื้นที่
        <strong style="font-weight:700;">dogsanook</strong> ปรากฏบนหน้าแรกของ Google
      </p>
    </div>

    <figure
      class="blueprint"
      style="margin:0;max-width:900px;background:#1c1c1e;padding:0;"
    >
      <i class="corner tl"></i><i class="corner tr"></i><i class="corner bl"></i><i
        class="corner br"
      ></i>
      <figcaption
        style="position:absolute;top:-11px;left:16px;z-index:2;background:var(--color-accent);color:#fff;font-family:var(--font-heading);font-weight:600;font-size:11px;letter-spacing:0.08em;padding:2px 10px;"
      >
        ผลการค้นหาจริง
      </figcaption>
      <Image
        src={serp}
        alt="ผลการค้นหา Google: dogsanook ปรากฏบนหน้าแรกเมื่อค้นหาฝึกสุนัข กรุงเทพกรีฑา"
        widths={[480, 800, 900]}
        sizes="(max-width: 940px) 100vw, 900px"
        loading="lazy"
        style="display:block;width:100%;height:auto;"
      />
    </figure>
    <p
      style="font-size:13px;line-height:1.6;color:color-mix(in srgb,var(--color-text) 55%,transparent);margin:16px 0 0;max-width:64ch;"
    >
      * ภาพผลการค้นหาจากเคส dogsanook ที่เราวางระบบให้จริง
      ผลอันดับบน Google ขึ้นกับหลายปัจจัยและเปลี่ยนแปลงได้
    </p>
  </div>
</section>
