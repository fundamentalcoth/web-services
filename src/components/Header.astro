---
import { Image } from 'astro:assets';
import { SITE } from '../site.config.ts';
import logo from '../assets/fundamental-logo.png';

const links = [
  { href: '#proof', label: 'ผลงานจริง' },
  { href: '#systems', label: 'ระบบ LINE' },
  { href: '/blog', label: 'บทความ' },
];
---
<header class="site-header">
  <div class="container nav-row">
    <a href="#top" class="brand" aria-label={`${SITE.brandName} — กลับสู่ด้านบน`}>
      <Image src={logo} alt="โลโก้ Fundamental" width={30} height={30} loading="eager" class="brand-logo" />
      <span class="brand-name">{SITE.brandName}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="เมนูหลัก">
      {links.map((l) => <a href={l.href} class="nav-link">{l.label}</a>)}
      <a href={SITE.lineUrl} class="btn btn-primary nav-cta" rel="noopener">ทักไลน์</a>
    </nav>

    <!-- Mobile nav: CTA always visible + hamburger (no JS, uses <details>) -->
    <div class="nav-mobile">
      <a href={SITE.lineUrl} class="btn btn-primary nav-cta" rel="noopener">ทักไลน์</a>
      <details class="nav-menu">
        <summary aria-label="เปิดเมนู">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <path d="M3 6h18M3 12h18M3 18h18" />
          </svg>
        </summary>
        <nav class="nav-panel" aria-label="เมนูหลัก">
          {links.map((l) => <a href={l.href} class="nav-panel-link">{l.label}</a>)}
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-divider);
  }
  .nav-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-block: 12px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-right: auto;
    color: var(--color-text);
  }
  .brand-logo {
    height: 30px;
    width: auto;
    display: block;
  }
  .brand-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 21px;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .nav-link {
    font-size: 13.5px;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
  }
  .nav-cta {
    font-size: 14px;
    padding: 9px 18px;
    white-space: nowrap;
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .nav-mobile {
    display: none;
    align-items: center;
    gap: 10px;
  }

  @media (max-width: 640px) {
    .nav-desktop { display: none; }
    .nav-mobile { display: flex; }
    .brand-name { font-size: 19px; }
  }

  /* Hamburger (details) */
  .nav-menu { position: relative; }
  .nav-menu > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--color-divider);
    color: var(--color-text);
  }
  .nav-menu > summary::-webkit-details-marker { display: none; }
  .nav-menu > summary:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
  .nav-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 9px);
    min-width: 168px;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-divider);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-text) 14%, transparent);
  }
  .nav-panel-link {
    padding: 13px 16px;
    font-size: 14.5px;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-divider);
  }
  .nav-panel-link:last-child { border-bottom: 0; }
  .nav-panel-link:hover { background: var(--color-surface); }
</style>
