---
import { Image } from 'astro:assets';
import { SITE } from '../site.config.ts';
import logo from '../assets/fundamental-logo.png';
---
<footer style="background:var(--color-bg);border-top:1px solid var(--color-divider);">
  <div
    class="container"
    style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:14px;padding-block:26px;"
  >
    <div style="display:flex;align-items:center;gap:10px;">
      <Image
        src={logo}
        alt="โลโก้ Fundamental"
        width={24}
        height={24}
        loading="lazy"
        style="height:24px;width:auto;display:block;"
      />
      <span style="font-family:var(--font-heading);font-weight:600;font-size:17px;letter-spacing:0.06em;"
        >{SITE.brandName}</span
      >
      <span
        style="font-family:var(--font-body);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:color-mix(in srgb,var(--color-text) 45%,transparent);"
        >fundamental.co.th</span
      >
    </div>
    <span
      style="font-family:var(--font-body);font-size:12.5px;color:color-mix(in srgb,var(--color-text) 55%,transparent);text-align:right;"
      >รับทำเว็บ + ระบบ LINE ให้ธุรกิจถูกค้นหาเจอและไม่พลาดโอกาส<br />
      บริการย่านกรุงเทพกรีฑา · รามคำแหง · ลาดกระบัง · สุวรรณภูมิ · สมุทรปราการ ·
      <a href={SITE.lineUrl} rel="noopener">ทัก LINE</a> ·
      <a href={`tel:${SITE.telephone}`}>โทร {SITE.telephoneDisplay}</a></span
    >
  </div>
</footer>
