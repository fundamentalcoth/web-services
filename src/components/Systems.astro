---
const cards = [
  {
    n: 'ตัวอย่างที่ 01',
    title: 'ระบบจองคิวผ่าน LINE',
    body:
      'สำหรับธุรกิจบริการที่ต้องนัดเวลา เช่น คลินิก ร้านทำผม สปา ลูกค้าเลือกวันเวลาและจองเองได้เลย',
    tagLabel: 'ลูกค้าได้:',
    tag: 'จองเองได้ ไม่ต้องรอโทร ไม่พลาดสายนอกเวลาทำการ',
  },
  {
    n: 'ตัวอย่างที่ 02',
    title: 'ระบบติดตามผ่าน LINE',
    body:
      'สำหรับธุรกิจที่งานมีความคืบหน้าให้ติดตาม ลูกค้า login เข้ามาดูสถานะของตัวเองได้ทุกเมื่อ',
    tagLabel: 'ทำจริงแล้ว:',
    tag: 'ที่ dogsanook เจ้าของหมาดูพัฒนาการการเรียนของน้องได้เอง',
  },
  {
    n: 'ตัวอย่างที่ 03',
    title: 'ระบบแจ้งเตือนผ่าน LINE',
    body:
      'สำหรับธุรกิจที่ต้องเตือนลูกค้าให้กลับมา เช่น ถึงรอบใช้บริการ หรือโปรที่ควรรู้',
    tagLabel: 'ลูกค้าได้:',
    tag: 'ไม่ลืมกลับมา ช่วยดึงลูกค้าเก่ากลับมาใช้บริการซ้ำ',
  },
];
---
<section
  id="systems"
  style="border-bottom:1px solid var(--color-divider);background:var(--color-surface);"
>
  <div class="container" style="padding-block:clamp(56px,8vw,104px);">
    <div style="max-width:56ch;margin-bottom:clamp(34px,5vw,52px);">
      <p
        style="font-family:var(--font-body);font-size:11.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-accent-700);margin:0 0 14px;"
      >
        เจอแล้ว ต้องไม่หลุดมือ
      </p>
      <h2 style="font-size:clamp(28px,4vw,44px);line-height:1.18;margin:0 0 16px;">
        ระบบผ่าน LINE ที่ต่อยอดให้ธุรกิจคุณ
      </h2>
      <p
        style="font-size:17px;line-height:1.7;color:color-mix(in srgb,var(--color-text) 78%,transparent);margin:0;"
      >
        ไม่ต้องมีฟีเจอร์เยอะ แต่ต้องตรงกับงานคุณ นี่คือตัวอย่างระบบที่เราทำได้ ลองนึกภาพกับธุรกิจของคุณดู
      </p>
    </div>

    <div
      style="display:grid;grid-template-columns:repeat(auto-fit,minmax(258px,1fr));gap:clamp(16px,2.2vw,26px);"
    >
      {
        cards.map((c) => (
          <div
            class="blueprint"
            style="padding:clamp(22px,2.4vw,30px);background:var(--color-bg);display:flex;flex-direction:column;"
          >
            <i class="corner tl" /><i class="corner tr" /><i class="corner bl" /><i class="corner br" />
            <span style="font-family:var(--font-heading);font-weight:600;font-size:12px;letter-spacing:0.12em;color:var(--color-accent-700);">
              {c.n}
            </span>
            <h3 style="font-size:24px;line-height:1.25;margin:10px 0 14px;">{c.title}</h3>
            <p style="font-size:14.5px;line-height:1.65;color:color-mix(in srgb,var(--color-text) 74%,transparent);margin:0 0 18px;flex:1;">
              {c.body}
            </p>
            <div style="border-top:1px solid var(--color-divider);padding-top:14px;font-size:13.5px;line-height:1.6;color:var(--color-text);">
              <span style="color:var(--color-accent-700);font-weight:600;">{c.tagLabel}</span> {c.tag}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
