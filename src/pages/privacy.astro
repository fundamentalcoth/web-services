---
import LegalLayout from '../layouts/LegalLayout.astro';
import { SITE } from '../site.config.ts';

const addr = `${SITE.address.streetAddress} ${SITE.address.addressLocality} ${SITE.address.addressRegion} ${SITE.address.postalCode}`;
---
<LegalLayout
  title="นโยบายความเป็นส่วนตัว | Fundamental"
  description="นโยบายความเป็นส่วนตัวของ Fundamental Co., Ltd. — วิธีที่เราเก็บ ใช้ และคุ้มครองข้อมูลส่วนบุคคลของคุณตาม PDPA"
  heading="นโยบายความเป็นส่วนตัว"
  updated="กรกฎาคม 2569"
>
  <p>
    {SITE.legalName} (&ldquo;เรา&rdquo;) เคารพความเป็นส่วนตัวของผู้ใช้บริการ และให้ความสำคัญกับการคุ้มครองข้อมูลส่วนบุคคล
    ตามพระราชบัญญัติคุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562 (PDPA) นโยบายนี้อธิบายว่าเราเก็บ ใช้ เปิดเผย
    และคุ้มครองข้อมูลของคุณอย่างไรเมื่อคุณติดต่อหรือใช้บริการของเรา
  </p>

  <h2>1. ข้อมูลที่เราเก็บรวบรวม</h2>
  <ul>
    <li><strong>ข้อมูลที่คุณให้เราโดยตรง</strong> เมื่อทักผ่าน LINE โทรศัพท์ หรือช่องทางอื่น เช่น ชื่อ เบอร์โทร ชื่อบัญชี LINE ข้อมูลธุรกิจ และรายละเอียดที่คุณแจ้งเพื่อให้เราให้บริการ</li>
    <li><strong>ข้อมูลการใช้งานเว็บไซต์</strong> เช่น หน้าเว็บที่เข้าชม เวลาที่เข้าชม และข้อมูลทางเทคนิคของอุปกรณ์/เบราว์เซอร์ ซึ่งอาจเก็บผ่านคุกกี้หรือเครื่องมือวิเคราะห์</li>
  </ul>

  <h2>2. วัตถุประสงค์ในการใช้ข้อมูล</h2>
  <ul>
    <li>ติดต่อกลับ ให้คำปรึกษา และนำเสนอบริการตามที่คุณสอบถาม</li>
    <li>ดำเนินการและส่งมอบงานตามที่ตกลง</li>
    <li>ปรับปรุงเว็บไซต์และคุณภาพบริการ</li>
    <li>ปฏิบัติตามกฎหมายที่เกี่ยวข้อง</li>
  </ul>

  <h2>3. การเปิดเผยข้อมูล</h2>
  <p>
    เรา<strong>ไม่ขายหรือให้เช่า</strong>ข้อมูลส่วนบุคคลของคุณแก่บุคคลภายนอก เราอาจเปิดเผยข้อมูลเท่าที่จำเป็นแก่
    ผู้ให้บริการที่ช่วยดำเนินงานของเรา (เช่น ผู้ให้บริการโฮสติ้ง แพลตฟอร์ม LINE) ภายใต้ข้อตกลงรักษาความลับ
    หรือเมื่อกฎหมายกำหนด
  </p>

  <h2>4. ระยะเวลาการเก็บรักษา</h2>
  <p>
    เราเก็บข้อมูลไว้เท่าที่จำเป็นตามวัตถุประสงค์ข้างต้น หรือตามระยะเวลาที่กฎหมายกำหนด เมื่อหมดความจำเป็น
    เราจะลบหรือทำให้ข้อมูลไม่สามารถระบุตัวตนได้
  </p>

  <h2>5. สิทธิของเจ้าของข้อมูล</h2>
  <p>ภายใต้ PDPA คุณมีสิทธิ ดังนี้:</p>
  <ul>
    <li>ขอเข้าถึงและขอสำเนาข้อมูลของคุณ</li>
    <li>ขอแก้ไขข้อมูลให้ถูกต้องเป็นปัจจุบัน</li>
    <li>ขอลบ ระงับการใช้ หรือคัดค้านการประมวลผลข้อมูล</li>
    <li>ขอถอนความยินยอมเมื่อใดก็ได้</li>
  </ul>
  <p>คุณสามารถใช้สิทธิได้โดยติดต่อเราตามช่องทางด้านล่าง</p>

  <h2>6. คุกกี้</h2>
  <p>
    เว็บไซต์อาจใช้คุกกี้เพื่อให้เว็บทำงานได้อย่างเหมาะสมและช่วยวิเคราะห์การใช้งาน คุณสามารถตั้งค่าเบราว์เซอร์
    เพื่อปฏิเสธคุกกี้ได้ แต่บางส่วนของเว็บไซต์อาจทำงานได้ไม่สมบูรณ์
  </p>

  <h2>7. ติดต่อเรา</h2>
  <p>
    หากมีคำถามเกี่ยวกับนโยบายนี้หรือต้องการใช้สิทธิของคุณ ติดต่อได้ที่:<br />
    <strong>{SITE.legalName}</strong><br />
    ที่อยู่: {addr}<br />
    โทร: <a href={`tel:${SITE.telephone}`}>{SITE.telephoneDisplay}</a><br />
    LINE: <a href={SITE.lineUrl} rel="noopener">ทักไลน์</a>
  </p>

  <h2>8. การเปลี่ยนแปลงนโยบาย</h2>
  <p>
    เราอาจปรับปรุงนโยบายนี้เป็นครั้งคราว โดยจะแสดงวันที่อัปเดตล่าสุดไว้ด้านบนของหน้า
    การใช้บริการต่อไปถือว่าคุณรับทราบนโยบายฉบับปรับปรุงแล้ว
  </p>
</LegalLayout>
